# Discord application id you own (https://discord.com/developers/applications)
HL_APP_ID=000000000000000000
# Prometheus base URL
PROM_URL=http://localhost:9090
# poll / frame-rotation seconds (Discord RPC floor is ~15s)
HL_POLL=20
# activity image: "auto" (app icon), an uploaded asset key, or an https URL
HL_IMAGE=auto
# NOTE: the script filters Prometheus by instance="pve" and a few host-specific
# metric names. Change those to match your own node's instance label + exporters.
