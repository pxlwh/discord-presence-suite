# Discord application id you own
DISCORD_APP_ID=000000000000000000
# Navidrome / Subsonic server + credentials
ND_URL=https://navidrome.example.com
ND_USER=your-navidrome-user
ND_PASS=your-navidrome-password
# optional: username to match in now-playing (defaults to ND_USER)
# ND_ME=your-navidrome-user
# optional: public cover-art proxy base (serves Navidrome's own art to Discord)
# COVER_FUNNEL=https://cover-proxy.example.com
