# Discord application id you own
DISCORD_APP_ID=000000000000000000
# Jellyfin server (LAN / VPN) + API key + username to track
JF_URL=http://jellyfin.local:8096
JF_API_KEY=your-jellyfin-api-key
JF_USERNAME=your-jellyfin-user
# public HTTPS base Discord can fetch cover art from (Jellyfin is usually private)
JF_COVER_BASE=https://cover-proxy.example.com
# optional: TMDB key for fallback cover art
TMDB_KEY=your-tmdb-key
# WebSocket endpoint of the presence renderer this bridge feeds
RPC_WS=ws://127.0.0.1:56727/ws
